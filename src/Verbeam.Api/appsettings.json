{
  "Urls": "http://localhost:5757",
  "Verbeam": {
    "DefaultProvider": "ollama",
    "DefaultMode": "game_dialogue",
    "DefaultSource": "ja",
    "DefaultTarget": "zh-TW",
    "PresetsDirectory": "presets",
    "GlossariesDirectory": "glossaries",
    "CachePath": "../../data/translations.sqlite",
    "Ollama": {
      "BaseUrl": "http://localhost:11434",
      "Model": "verbeam-mort-qwen2.5-0.5b:latest",
      "Models": [
        "verbeam-mort-qwen2.5-0.5b:latest"
      ],
      "ModelDiscoveryTimeoutSeconds": 2,
      "TimeoutSeconds": 30,
      "NumContext": 1024,
      "NumPredict": 64,
      "Temperature": 0,
      "KeepAlive": "30m"
    },
    "Ocr": {
      "DefaultProvider": "external",
      "DefaultLanguage": "ja",
      "MaxImageBytes": 4194304,
      "NormalizeWhitespace": true,
      "External": {
        "FileName": "powershell",
        "Arguments": "-NoProfile -ExecutionPolicy Bypass -File \"..\\..\\scripts\\windows_ocr_json.ps1\" -Image {image} -Language {language}",
        "TimeoutSeconds": 15
      },
      "LocalSet": {
        "PythonFileName": "python",
        "VenvPythonPath": "../../.ocr-set/venv/Scripts/python.exe",
        "ScriptPath": "../../scripts/local_ocr_json.py",
        "TimeoutSeconds": 180,
        "CheckTimeoutSeconds": 5
      }
    },
    "Speech": {
      "DefaultProvider": "funasr-http",
      "DefaultLanguage": "ja",
      "MaxAudioBytes": 67108864,
      "PreferCaptions": true,
      "FunAsrHttp": {
        "BaseUrl": "http://localhost:8000",
        "Model": "sensevoice",
        "ResponseFormat": "verbose_json",
        "TimeoutSeconds": 120
      },
      "External": {
        "FileName": "",
        "Arguments": "{audio} {language}",
        "TimeoutSeconds": 120
      },
      "YouTube": {
        "YtDlpFileName": "yt-dlp",
        "FfmpegFileName": "ffmpeg",
        "AudioFormat": "bestaudio[abr<=64]/bestaudio/best",
        "TimeoutSeconds": 900,
        "AudioChunkSeconds": 600
      },
      "Live": {
        "SampleRate": 16000,
        "Channels": 1,
        "BitsPerSample": 16,
        "MaxSegmentSeconds": 8,
        "SilenceDurationMs": 700,
        "SilenceRmsThreshold": 0.01
      }
    },
    "ContextCompression": {
      "Enabled": true,
      "MaxCharacters": 1800,
      "HeadCharacters": 900,
      "TailCharacters": 700
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
