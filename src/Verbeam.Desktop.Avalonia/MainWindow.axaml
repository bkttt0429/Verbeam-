    <Style Selector="Border.providerCatalogHint">
      <Setter Property="Background" Value="#0B1826" />
      <Setter Property="BorderBrush" Value="#244864" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="10,7" />
