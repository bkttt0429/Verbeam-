    </Style>
    <Style Selector="Border.providerHero">
      <Setter Property="Background" Value="#0F151E" />
      <Setter Property="BorderBrush" Value="#263349" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="Padding" Value="12" />
    </Style>
